{
  "compilerOptions": {
    "target": "esnext",
    "module": "es2015",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "strict": true,
    "preserveConstEnums": true,
    "jsx": "preserve",
    "noEmit": true,
    "typeRoots": ["./node_modules/@types", "./types"],
    "types": ["jest"],
    "skipLibCheck": true,
    "paths": {
      "react-magnetic-di": ["./types"]
    }
  },
  "include": ["examples/**/*"]
}
